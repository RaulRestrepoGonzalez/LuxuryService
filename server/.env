MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=luxury_service
JWT_SECRET=dev-luxury-secret-cambiar-en-produccion
PORT=3000

# Credibanco Checkout
CREDIBANCO_MERCHANT_ID=
CREDIBANCO_API_KEY=
CREDIBANCO_API_URL=https://api.credibanco.com/checkout/v1/sessions
CREDIBANCO_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# CORREO ELECTRÓNICO (SMTP) — OBLIGATORIO PARA PRODUCCIÓN
# ─────────────────────────────────────────────────────────────────────────────
# Usamos BREVO (gratis, 300 emails/día, excelente entregabilidad).
# Sin esto los correos NO llegarán a los clientes.
#
# CÓMO ACTIVAR (3 minutos):
#   1. Ve a https://www.brevo.com/ y crea cuenta GRATIS (no pide tarjeta)
#   2. Ve a SMTP & API > SMTP Keys > "Create a new SMTP key"
#   3. Copia la clave SMTP (empieza con "xsmtp...")
#   4. Pégala abajo en SMTP_PASS
#   5. Guarda este archivo y reinicia el servidor
#   6. El sistema verificará la conexión automáticamente
#   7. En el panel admin (Email > Enviar prueba) confirma que llega
#
# NOTA: SMTP_USER es tu correo CON EL QUE TE REGISTRASTE en Brevo
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=notificaciones@luxuryservice.co
SMTP_FROM_NAME=Luxury Service Manga
# ─────────────────────────────────────────────────────────────────────────────
# OPCIÓN 2 — Gmail (para desarrollo)
#   · Requiere App Password (16 caracteres)
#   · Límite: ~500 emails/día
#   · Pasos: Seguridad > Verificación en 2 pasos > App Passwords
#   · SMTP_USER = tu correo completo, SMTP_PASS = App Password SIN espacios
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=notificaciones.luxuryservice@gmail.com
# SMTP_PASS=abcd efgh ijkl mnop   (App Password 16 chars, sin espacios)
# SMTP_FROM=notificaciones.luxuryservice@gmail.com
# SMTP_FROM_NAME=Luxury Service Manga
# ─────────────────────────────────────────────────────────────────────────────
# OPCIÓN 3 — Outlook / Hotmail
#
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=notificaciones@outlook.com
# SMTP_PASS=tu_contraseña
# SMTP_FROM=notificaciones@outlook.com
# SMTP_FROM_NAME=Luxury Service Manga
# ─────────────────────────────────────────────────────────────────────────────
# OPCIÓN 4 — Amazon SES (producción escala)
#
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=AKIA...
# SMTP_PASS=BH...
# SMTP_FROM=notificaciones@tudominio.com
# SMTP_FROM_NAME=Luxury Service Manga
# ─────────────────────────────────────────────────────────────────────────────
# DKIM (opcional, mejora entregabilidad)
# Configura registros DKIM en tu DNS para el dominio del remitente.
# SMTP_DKIM_DOMAIN=tudominio.com
# SMTP_DKIM_SELECTOR=default
# SMTP_DKIM_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# ─────────────────────────────────────────────────────────────────────────────
# Cola de correos pendientes (reintento automático cada N ms)
# EMAIL_RETRY_INTERVAL_MS=300000   # cada 5 minutos
# EMAIL_MAX_RETRIES=10             # máximo 10 intentos antes de abandonar
# ─────────────────────────────────────────────────────────────────────────────

# URL base (para enlaces en correos)
BASE_URL=http://localhost:4200
