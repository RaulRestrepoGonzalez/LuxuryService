CREDIBANCO_WEBHOOK_SECRET=

# SMTP (correo para enviar tickets y notificaciones a clientes)
# Si se deja vacío, se usa envío DIRECTO al servidor MX del destinatario
# (sin configuración, funciona automáticamente)
#
# Configuración opcional para usar un relay SMTP (más confiable):
#
# OPCIÓN #1 — OUTLOOK (tu correo existente: luxuryservicemss@outlook.com)
# Usa tu contraseña normal de Outlook. Si tienes verificación en 2 pasos,
# genera una Contraseña de Aplicación en https://account.live.com/security
#
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=luxuryservicemss@outlook.com
# SMTP_PASS=COLOCA_TU_CONTRASEÑA_AQUI
# SMTP_FROM=luxuryservicemss@outlook.com
#
# OPCIÓN #2 — GMAIL (App Password, 500 emails/día gratis)
# 1. Crea o usa una cuenta Gmail (ej. luxuryservice.talleres@gmail.com)
# 2. Activa verificación en 2 pasos: https://myaccount.google.com/security
# 3. Genera App Password: https://myaccount.google.com/apppasswords
# 4. Copia el password de 16 caracteres sin espacios
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=luxuryservice.talleres@gmail.com
# SMTP_PASS=abcd efgh ijkl mnop   (App Password 16 caracteres, sin espacios)
# SMTP_FROM=luxuryservice.talleres@gmail.com
# SMTP_FROM_NAME=Luxury Service Manga
#
# OPCIÓN #3 — BREVO (Sendinblue, 300 emails/día gratis)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=COLOCA_TU_EMAIL
# SMTP_PASS=COLOCA_TU_SMTP_KEY
# SMTP_FROM=COLOCA_TU_EMAIL
# SMTP_FROM_NAME=Luxury Service Manga

# URL base (para enlaces en correos)
BASE_URL=http://localhost:4200
