# ─────────────────────────────────────────────────────────────────────────────
# CORREO ELECTRÓNICO (SMTP) — OBLIGATORIO PARA PRODUCCIÓN
# ─────────────────────────────────────────────────────────────────────────────
# Usamos GMAIL con App Password.
#
# CÓMO ACTIVAR (3 minutos, necesitas cuenta de Google):
#   1. Ve a https://myaccount.google.com/security
#   2. Activa "Verificación en 2 pasos" (si no la tienes)
#   3. Ve a "Contraseñas de aplicaciones"
#   4. Crea una para "Correo" + "Otro" → pon nombre "LuxuryService"
#   5. Google te da una clave de 16 letras (ej: abcd efgh ijkl mnop)
#   6. Pega tu correo en SMTP_USER y la CLAVE (sin espacios) en SMTP_PASS
#   7. Guarda y reinicia el servidor
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Luxury Service Manga
# ─────────────────────────────────────────────────────────────────────────────
# OPCIÓN 2 — Outlook / Hotmail
#   · Puede usar contraseña normal o App Password
#   · Límite: ~300 emails/día
#
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=notificaciones@outlook.com
# SMTP_PASS=tu_contraseña_o_app_password
# SMTP_FROM=notificaciones@outlook.com
# SMTP_FROM_NAME=Luxury Service Manga
# ─────────────────────────────────────────────────────────────────────────────
# OPCIÓN 3 — Brevo (alternativa gratuita, 300/día)
#   SMTP_HOST=smtp-relay.sendinblue.com
#   SMTP_PORT=587
#   SMTP_USER=tu_correo_registrado
#   SMTP_PASS=tu_clave_smtp
#   SMTP_FROM=tucorreo@ejemplo.com
# ─────────────────────────────────────────────────────────────────────────────
# OPCIÓN 4 — Amazon SES (producción escala)
#
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=AKIA...
# SMTP_PASS=BH...
# SMTP_FROM=notificaciones@tudominio.com
# SMTP_FROM_NAME=Luxury Service Manga
# ─────────────────────────────────────────────────────────────────────────────
# DKIM (opcional, mejora entregabilidad)
# Configura registros DKIM en tu DNS para el dominio del remitente.
# SMTP_DKIM_DOMAIN=tudominio.com
# SMTP_DKIM_SELECTOR=default
# SMTP_DKIM_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# ─────────────────────────────────────────────────────────────────────────────
# Cola de correos pendientes (reintento automático cada N ms)
# EMAIL_RETRY_INTERVAL_MS=300000   # cada 5 minutos
# EMAIL_MAX_RETRIES=10             # máximo 10 intentos antes de abandonar
# ─────────────────────────────────────────────────────────────────────────────

# URL base (para enlaces en correos)
BASE_URL=http://localhost:4200
